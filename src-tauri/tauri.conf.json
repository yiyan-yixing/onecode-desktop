{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OneCode Desktop",
  "version": "0.1.0",
  "identifier": "com.onecode.desktop",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "npm run copy-static",
    "beforeBuildCommand": "npm run copy-static"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "devtools": false,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https://api.anthropic.com https://api.openai.com; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "appimage", "deb", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "publisher": "YiYan YiXing",
    "copyright": "© 2025 YiYan YiXing. MIT License.",
    "shortDescription": "Multi-kernel AI terminal manager",
    "longDescription": "OneCode Desktop — manage multiple AI coding terminals (Claude Code, OpenCode, Codex, etc.) in one native window."
  }
}
