{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OneCode Desktop",
  "version": "0.1.0",
  "identifier": "com.onecode.desktop",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "npm run copy-static",
    "beforeBuildCommand": "npm run copy-static"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OneCode · AI 原生 IDE",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Multi-terminal AI desktop client",
    "longDescription": "OneCode Desktop — manage multiple Claude Code terminals in one native window."
  }
}
